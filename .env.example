# Copy to .env.local and fill in.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email/CRM endpoint for the contact form (wire this in src/components/sections/contact-form.tsx)
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=

# ─── Instagram Graph API (optional) ──────────────────────────────────
# Long-lived access token from Meta's Graph API for an Instagram
# Business or Creator account. When set, src/lib/instagram.ts pulls
# recent VIDEO/REELS posts and feeds them into <InstagramCarousel />.
# When unset, the carousel falls back to seeded data in src/data/reels.ts.
#
# Setup:
# 1. Convert your IG account to Business or Creator (Settings → Account type).
# 2. Link a Facebook Page to the IG account.
# 3. Create an app at https://developers.facebook.com/apps/ → add "Instagram Graph API".
# 4. Generate a long-lived (60-day) access token via Graph API Explorer.
# 5. Refresh tokens before expiry (a small cron / scheduled job in production).
# INSTAGRAM_ACCESS_TOKEN=
